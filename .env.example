ACTIVE_MONITOR=2  # Browser läuft auf Monitor 2 (rechts)

# Florence-2 Vision Tool
FLORENCE2_ENABLED=true                          # false → alter Qwen/GPT-4-Pfad
FLORENCE2_MODEL=microsoft/Florence-2-large-ft   # oder Florence-2-base-ft (~1.5GB)

# LLM-Fallback (Decision-Layer) — optional, nur wenn lokaler LLM läuft
LOCAL_LLM_URL=http://localhost:1234/v1          # LM Studio / Ollama / vLLM
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct       # Modell-Name auf dem lokalen Server

# Executor Agent (Tool-Use, schnelle Tasks)
FAST_MODEL=claude-haiku-4-5-20251001   # Anthropic Haiku 4.5 — beste Tool-Use-Zuverlässigkeit
FAST_MODEL_PROVIDER=anthropic

# Agent-zu-Agent Delegation
DELEGATION_TIMEOUT=120       # Max. Sekunden pro Delegation (Default: 120)
DELEGATION_MAX_RETRIES=1     # Max. Versuche bei Fehler (Default: 1 = kein Retry)
