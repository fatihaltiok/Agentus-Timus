ACTIVE_MONITOR=2  # Browser läuft auf Monitor 2 (rechts)

# ==============================================================================
# DEEP RESEARCH v7.0 — Domain-aware Pipeline
# ==============================================================================
# Embedding-Threshold für Tech-Domain (KI, ML, ArXiv): 0.72 statt 0.85
DR_EMBEDDING_THRESHOLD_TECH=0.72
# Auto-Mode: strict + Tech-Domain → moderate (damit KI-Fakten nicht verschwinden)
DR_VERIFICATION_MODE_AUTO=true
# ArXiv Relevanz-Threshold (0–10): 5 = mehr Paper, 7 = strenger
# ARXIV_RELEVANCE_THRESHOLD=5

# ==============================================================================
# TIMUS E-MAIL (Outlook.com)
# Setup: SMTP AUTH unter Outlook.com > Einstellungen > E-Mail > Synchronisieren
#        > POP und IMAP > SMTP aktivieren
# ==============================================================================
TIMUS_EMAIL=timus.agent@outlook.com
TIMUS_EMAIL_PASSWORD=
TIMUS_EMAIL_DISPLAY_NAME=Timus Agent
TIMUS_EMAIL_IMAP_HOST=outlook.office365.com
TIMUS_EMAIL_IMAP_PORT=993
TIMUS_EMAIL_SMTP_HOST=smtp-mail.outlook.com
TIMUS_EMAIL_SMTP_PORT=587

# RealSense Live-Stream (D435)
REALSENSE_STREAM_AUTO_START=false      # true = startet Stream beim MCP-Server-Start
REALSENSE_STREAM_DEVICE=               # optional: /dev/video Index (z.B. 4); leer = auto
REALSENSE_STREAM_WIDTH=1280
REALSENSE_STREAM_HEIGHT=720
REALSENSE_STREAM_FPS=10
REALSENSE_STREAM_MAX_AGE_SEC=3.0
REALSENSE_STREAM_AUTO_START_FOR_IMAGE=1  # ImageAgent startet Stream bei Kamera-Intent automatisch
REALSENSE_CAPTURE_DIR=
REALSENSE_CAPTURE_PREFIX=timus_d435
REALSENSE_CAPTURE_DEPTH=0

# Florence-2 Vision Tool
FLORENCE2_ENABLED=true                          # false → alter Qwen/GPT-4-Pfad
FLORENCE2_MODEL=microsoft/Florence-2-large-ft   # oder Florence-2-base-ft (~1.5GB)

# LLM-Fallback (Decision-Layer) — optional, nur wenn lokaler LLM läuft
LOCAL_LLM_URL=http://localhost:1234/v1          # LM Studio / Ollama / vLLM
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct       # Modell-Name auf dem lokalen Server

# Dispatcher Router (welches LLM die Agent-Auswahl trifft)
DISPATCHER_MODEL=gpt-5-mini
DISPATCHER_MODEL_PROVIDER=openai

# Direkter z.ai / GLM-Zugriff (OpenAI-kompatible API)
ZAI_API_BASE=https://api.z.ai/api/paas/v4
ZAI_API_KEY=

# SerpApi (YouTube Video / Transcript)
SERPAPI_API_KEY=

# Google Maps / Reverse Geocoding fuer Mobil-Standorte
GOOGLE_MAPS_API_KEY=
TIMUS_LOCATION_LIVE_MAX_AGE_SECONDS=600
TIMUS_LOCATION_RECENT_MAX_AGE_SECONDS=3600
TIMUS_LOCATION_MAX_CONTEXT_ACCURACY_METERS=250

# Optionale Kostenraten fuer LLM-Usage-Telemetrie (USD pro 1M Tokens)
# Kann global pro Provider oder modellspezifisch gesetzt werden.
# Beispiele:
# TIMUS_LLM_PRICE_OPENAI_INPUT_USD_PER_1M=1.25
# TIMUS_LLM_PRICE_OPENAI_OUTPUT_USD_PER_1M=10.00
# TIMUS_LLM_PRICE_OPENROUTER_Z_AI_GLM_5_INPUT_USD_PER_1M=0.80
# TIMUS_LLM_PRICE_OPENROUTER_Z_AI_GLM_5_OUTPUT_USD_PER_1M=3.20
# TIMUS_LLM_PRICE_OPENAI_CACHED_INPUT_USD_PER_1M=0.15

# Laufzeit-Budgets fuer LLM-Nutzung (USD im Budgetfenster)
TIMUS_LLM_BUDGET_WINDOW_DAYS=1
TIMUS_LLM_BUDGET_SOFT_MAX_TOKENS=600
TIMUS_LLM_BUDGET_GLOBAL_WARN_USD=0
TIMUS_LLM_BUDGET_GLOBAL_SOFT_LIMIT_USD=0
TIMUS_LLM_BUDGET_GLOBAL_HARD_LIMIT_USD=0
TIMUS_LLM_BUDGET_AGENT_WARN_USD=0
TIMUS_LLM_BUDGET_AGENT_SOFT_LIMIT_USD=0
TIMUS_LLM_BUDGET_AGENT_HARD_LIMIT_USD=0
TIMUS_LLM_BUDGET_SESSION_WARN_USD=0
TIMUS_LLM_BUDGET_SESSION_SOFT_LIMIT_USD=0
TIMUS_LLM_BUDGET_SESSION_HARD_LIMIT_USD=0
TIMUS_LLM_BUDGET_WARN_MAX_PARALLEL=0
TIMUS_LLM_BUDGET_SOFT_MAX_PARALLEL=2
TIMUS_LLM_BUDGET_HARD_MAX_PARALLEL=1
# Optionales Soft-Limit-Downgrade auf guenstigere Modelle
# TIMUS_LLM_BUDGET_DEFAULT_SOFT_PROVIDER=openrouter
# TIMUS_LLM_BUDGET_DEFAULT_SOFT_MODEL=google/gemini-3.1-flash-lite-preview
# TIMUS_LLM_BUDGET_DISPATCHER_SOFT_PROVIDER=zai
# TIMUS_LLM_BUDGET_DISPATCHER_SOFT_MODEL=glm-5-air

# Executor Agent (Tool-Use, schnelle Tasks)
FAST_MODEL=gemini-3-flash-preview      # Neuer Gemini-Flash-Pfad fuer Executor (Preview, aber aktueller)
FAST_MODEL_PROVIDER=google
# Alternativen:
# FAST_MODEL=gpt-5-mini
# FAST_MODEL_PROVIDER=openai
# FAST_MODEL=claude-3-5-haiku-latest
# FAST_MODEL_PROVIDER=anthropic
# FAST_MODEL=gemini-2.5-flash
# FAST_MODEL_PROVIDER=google

# Visual Agent (Desktop-Automation + Computer Use)
VISUAL_MODEL=gpt-5.4-2026-03-05        # GPT-5.4 Computer Use — direkt via OpenAI API
VISUAL_MODEL_PROVIDER=openai           # "openai" oder "openrouter" (Fallback: nvidia/nemotron)
OPENROUTER_VISION_MODEL=Qwen3.5-397B-A17B  # separater OpenRouter-Vision-Fallback fuer visual_nemotron

# Reasoning Agent (Vergleiche, Analyse, Debugging)
REASONING_MODEL=qwen/qwq-32b           # QwQ-32B — speziell für Reasoning konzipiert
REASONING_MODEL_PROVIDER=openrouter    # OpenRouter! NVIDIA NIM → 504 Gateway Timeout bei langen Thinking-Tasks

# NVIDIA NIM Timeout (nur für ModelProvider.NVIDIA — nicht für OpenRouter)
NVIDIA_TIMEOUT=360                     # Sekunden (Default war 120 → zu kurz für Thinking-Modelle)

# Heartbeat / Autonomy-Loop
HEARTBEAT_INTERVAL_MINUTES=3  # Takt des AutonomousRunner-Heartbeats (Default: 3 min)
AUTONOMY_META_ANALYSIS_INTERVAL_HEARTBEATS=20  # Meta-Analyse alle N Ticks (20×3min=60min)

# Agent-zu-Agent Delegation
DELEGATION_TIMEOUT=120       # Max. Sekunden pro Delegation (Default: 120)
DELEGATION_MAX_RETRIES=1     # Max. Versuche bei Fehler (Default: 1 = kein Retry)
RESEARCH_TIMEOUT=600         # Separater Timeout für Research-Agent (Default: 600s — Deep Research braucht 300-600s)


# ==============================================================================
# MEMORY SYSTEM (v2.2 — Hardening 2026-02-25)
# ==============================================================================
# Alle Werte haben Defaults — diese Sektion ist optional.

MAX_SESSION_MESSAGES=50       # Letzte N Nachrichten im Kontext (Default: 50, war: 20)
MAX_CONTEXT_TOKENS=16000      # Max Token für Memory-Kontext (Default: 16000, war: 2000)
SUMMARIZE_THRESHOLD=20        # Auto-Summarize alle N Nachrichten (Default: 20, war: 10)
WM_MAX_CHARS=10000            # Working Memory max. Zeichen (Default: 10000, war: 3200)
WM_MAX_RELATED=8              # Verwandte Erinnerungen im Working Memory (Default: 8, war: 4)
WM_MAX_EVENTS=15              # Aktuelle Events im Working Memory (Default: 15, war: 6)
UNIFIED_RECALL_MAX_SCAN=200   # Recall-Scan-Tiefe (Default: 200, war: 80)
MAX_OUTPUT_TOKENS=16000       # ContextGuard Output-Limit (Default: 16000, war: implizit 8000)

# ==============================================================================
# CURIOSITY ENGINE (v2.8)
# ==============================================================================
CURIOSITY_ENABLED=true           # false = deaktiviert
CURIOSITY_MIN_HOURS=3            # Frühestes Aufwachen (Stunden)
CURIOSITY_MAX_HOURS=14           # Spätestes Aufwachen (Stunden)
CURIOSITY_GATEKEEPER_MIN=7       # Gatekeeper-Score-Minimum (1-10)
CURIOSITY_MAX_PER_DAY=2          # Anti-Spam: max. N Nachrichten/Tag

# ==============================================================================
# SOUL ENGINE (v2.8)
# ==============================================================================
SOUL_DRIFT_ENABLED=true          # false = Achsen einfrieren
SOUL_DRIFT_DAMPING=0.1           # Dämpfungsfaktor (0.0=kein Drift, 1.0=voller Drift)
SOUL_AXES_CLAMP_MIN=5            # Untergrenze aller Achsen
SOUL_AXES_CLAMP_MAX=95           # Obergrenze aller Achsen

# ==============================================================================
# AUTONOMY 9/10 ROADMAP (M0 Baseline)
# ==============================================================================
# WICHTIG: Alle neuen Autonomie-Features starten im kompatiblen OFF-Modus.
# Aktivierung erfolgt schrittweise pro Meilenstein.

AUTONOMY_GOALS_ENABLED=false             # M1: Eigenständige Zielhierarchie
AUTONOMY_PLANNING_ENABLED=false          # M2: Langzeit-Planung (Tag/Woche/Monat)
AUTONOMY_REPLANNING_ENABLED=false        # M2: Re-Planning bei Drift/Fehler
AUTONOMY_SELF_HEALING_ENABLED=false      # M3: Recovery-Playbooks + Circuit Breaker
AUTONOMY_SELF_HEALING_BREAKER_FAILURE_THRESHOLD=3
AUTONOMY_SELF_HEALING_BREAKER_COOLDOWN_SEC=600
AUTONOMY_SELF_HEALING_MAX_PLAYBOOK_ATTEMPTS=3
AUTONOMY_SELF_HEALING_ESCALATE_AFTER_MIN=30
AUTONOMY_SELF_HEALING_ESCALATION_LIMIT_PER_CYCLE=3
AUTONOMY_SELF_HEALING_PENDING_THRESHOLD=30
AUTONOMY_SELF_HEALING_FAILURE_WINDOW_MIN=60
AUTONOMY_SELF_HEALING_FAILURE_THRESHOLD=6
AUTONOMY_SELF_HEALING_MCP_HEALTH_URL=http://127.0.0.1:5000/health
AUTONOMY_SELF_HEALING_HTTP_TIMEOUT_SEC=2.0
AUTONOMY_SELF_HEALING_DEGRADED_OPEN_THRESHOLD=2
AUTONOMY_SELF_HEALING_DEGRADED_BREAKERS_OPEN_THRESHOLD=1
AUTONOMY_SELF_HEALING_EMERGENCY_OPEN_THRESHOLD=4
AUTONOMY_SELF_HEALING_EMERGENCY_BREAKERS_OPEN_THRESHOLD=2
AUTONOMY_SELF_HEALING_EMERGENCY_HIGH_SEVERITY_THRESHOLD=2
AUTONOMY_POLICY_GATES_STRICT=false       # M4: Formale Security-Gates (strict mode)
AUTONOMY_AUDIT_DECISIONS_ENABLED=false   # M4: Audit-Entscheidungsprotokoll
AUTONOMY_CANARY_PERCENT=0                # Rollout-Anteil neuer Features (0-100)
AUTONOMY_POLICY_ROLLBACK_ENABLED=false   # M4.4: Auto-Rollback bei Policy-Spikes
AUTONOMY_POLICY_ROLLBACK_WINDOW_HOURS=1
AUTONOMY_POLICY_ROLLBACK_MIN_DECISIONS=20
AUTONOMY_POLICY_ROLLBACK_BLOCK_RATE_PCT=40
AUTONOMY_POLICY_ROLLBACK_COOLDOWN_MIN=60
AUTONOMY_SCORECARD_ENABLED=false         # M5.1: Aggregierter Autonomie-Reifegrad
AUTONOMY_SCORECARD_WINDOW_HOURS=24
AUTONOMY_SCORECARD_CONTROL_ENABLED=false # M5.2: Scorecard-basierter Control-Loop
AUTONOMY_SCORECARD_PROMOTE_THRESHOLD=80
AUTONOMY_SCORECARD_ROLLBACK_THRESHOLD=55
AUTONOMY_SCORECARD_PROMOTE_STEP=10
AUTONOMY_SCORECARD_MAX_CANARY=100
AUTONOMY_SCORECARD_CONTROL_COOLDOWN_MIN=120
AUTONOMY_SCORECARD_ADAPTIVE_THRESHOLDS_ENABLED=false # M5.3: trendbasierte Schwellen
AUTONOMY_SCORECARD_TREND_BASELINE_DAYS=30
AUTONOMY_SCORECARD_GOVERNANCE_ENABLED=false # M5.4: harte Governance Guards
AUTONOMY_SCORECARD_MIN_PILLAR_SCORE=60
AUTONOMY_SCORECARD_CRITICAL_PILLAR_SCORE=40
AUTONOMY_SCORECARD_FREEZE_ON_DECLINING=true
AUTONOMY_SCORECARD_DECLINE_DELTA=-6
AUTONOMY_SCORECARD_VOLATILITY_FREEZE_THRESHOLD=12
AUTONOMY_AUDIT_REPORT_ENABLED=false      # M6.1: automatischer Audit-Report-Export
AUTONOMY_AUDIT_REPORT_CADENCE_HOURS=6
AUTONOMY_AUDIT_REPORT_WINDOW_DAYS=7
AUTONOMY_AUDIT_REPORT_BASELINE_DAYS=30
AUTONOMY_AUDIT_CHANGE_REQUESTS_ENABLED=false # M6.2: Audit-Empfehlung -> Change-Request
AUTONOMY_AUDIT_CHANGE_REQUEST_MIN_INTERVAL_MIN=30
AUTONOMY_AUDIT_CHANGE_PROMOTE_STEP=5
AUTONOMY_AUDIT_CHANGE_MAX_CANARY=100
AUTONOMY_AUDIT_CHANGE_APPROVAL_ENABLED=false # M6.3: Approval-Gates fuer Change-Requests
AUTONOMY_AUDIT_CHANGE_APPROVAL_REQUIRED_ACTIONS=rollback,promote
AUTONOMY_AUDIT_CHANGE_APPROVAL_PROMOTE_MIN_STEP=10
AUTONOMY_AUDIT_CHANGE_AUTO_APPROVE=false
AUTONOMY_AUDIT_CHANGE_AUTO_APPROVER=system
AUTONOMY_AUDIT_CHANGE_APPROVAL_SLA_HOURS=12
AUTONOMY_AUDIT_CHANGE_APPROVAL_ESCALATION_ENABLED=true
AUTONOMY_AUDIT_CHANGE_APPROVAL_ESCALATION_TASK_ENABLED=true
AUTONOMY_AUDIT_CHANGE_APPROVAL_ESCALATION_MIN_INTERVAL_MIN=60
AUTONOMY_AUDIT_CHANGE_APPROVAL_AUTO_REJECT_ON_TIMEOUT=false
AUTONOMY_HARDENING_ENABLED=false        # M7: Hardening + Rollout-Gate
AUTONOMY_HARDENING_ENFORCE=false
AUTONOMY_HARDENING_WINDOW_HOURS=24
AUTONOMY_HARDENING_MAX_OPEN_INCIDENTS=2
AUTONOMY_HARDENING_MIN_RECOVERY_RATE_24H=70
AUTONOMY_HARDENING_MAX_POLICY_BLOCK_RATE_24H=35
AUTONOMY_HARDENING_MAX_PENDING_APPROVALS=5
AUTONOMY_HARDENING_MIN_AUTONOMY_SCORE=75
AUTONOMY_HARDENING_ROLLBACK_ON_RED=true
AUTONOMY_HARDENING_FREEZE_ON_YELLOW=true
AUTONOMY_COMPAT_MODE=true                # Erzwingt kompatibles Verhalten bei Rollback

# ==============================================================================
# DEEP RESEARCH — TREND-TRACKING (ArXiv, GitHub, HuggingFace, Edison)
# ==============================================================================
DEEP_RESEARCH_TRENDS_ENABLED=true   # Phase 7: Trends (ArXiv/GitHub/HF) — kostenlose APIs

# Individuelle Quell-Toggles (auch per Canvas UI schaltbar, kein Neustart nötig)
DEEP_RESEARCH_ARXIV_ENABLED=true    # ArXiv wissenschaftliche Paper (Atom-XML, kostenlos)
DEEP_RESEARCH_GITHUB_ENABLED=true   # GitHub Top-Repositories (60 req/h anonym)
DEEP_RESEARCH_HF_ENABLED=true       # HuggingFace Models + Daily Papers (kostenlos)

# GitHub-Token optional (ohne: 60 req/h anonym, mit: 5000 req/h)
# GITHUB_TOKEN=ghp_...

# HuggingFace-Token optional (für private Modelle; öffentliche APIs funktionieren auch ohne)
# HF_TOKEN=hf_...

# Edison Scientific (PaperQA3) — https://platform.edisonscientific.com/profile
# ACHTUNG: Kostenloser Plan = 10 Credits/Monat → standardmäßig DEAKTIVIERT
# Nur gezielt aktivieren (z.B. vor einer wichtigen Recherche) oder per Canvas-Toggle
DEEP_RESEARCH_EDISON_ENABLED=false
EDISON_API_KEY=your_key_here

# ==============================================================================
# AUTONOMY v4.0 — M8–M12 Feature-Flags
# ==============================================================================

# ── M8: Session Reflection Loop ─────────────────────────────────────────────
AUTONOMY_REFLECTION_ENABLED=false
REFLECTION_IDLE_THRESHOLD_MIN=30    # Pause in Minuten → Session gilt als beendet
REFLECTION_TELEGRAM_ENABLED=true

# ── M9: Agent Blackboard (geteiltes Kurzzeit-Gedächtnis) ────────────────────
AUTONOMY_BLACKBOARD_ENABLED=true    # sofort aktiv (non-breaking)
BLACKBOARD_DEFAULT_TTL_MIN=60       # Standard-Ablaufzeit in Minuten

# ── M10: Proactive Triggers (zeitgesteuerte Routinen) ───────────────────────
AUTONOMY_PROACTIVE_TRIGGERS_ENABLED=false
TRIGGER_MORNING_ENABLED=false       # 08:00 E-Mail-Check (Mo–Fr)
TRIGGER_EVENING_ENABLED=false       # 20:00 Tages-Reflexion (täglich)

# ── M11: Goal Queue Manager (hierarchische Ziele) ───────────────────────────
AUTONOMY_GOAL_QUEUE_ENABLED=true    # sofort aktiv (nutzt bestehende Tabellen)

# ── M12: Self-Improvement Engine (Routing + Tool-Analyse) ───────────────────
AUTONOMY_SELF_IMPROVEMENT_ENABLED=false
SELF_IMPROVEMENT_ANALYSIS_DAYS=7    # Wöchentliche Analyse
IMPROVEMENT_MIN_SAMPLES=10          # Mindest-Datenpunkte vor Vorschlag

# ── M18: Self-Modification Engine ────────────────────────────────────────────
AUTONOMY_SELF_MODIFY_ENABLED=false   # true = Timus kann eigenen Code ändern
SELF_MODIFY_REQUIRE_APPROVAL=true    # Telegram-Bestätigung für Core-Dateien
SELF_MODIFY_REQUIRE_TESTS=true       # Tests müssen nach Änderung grün sein
SELF_MODIFY_MAX_PER_CYCLE=3          # Max. Modifikationen pro Heartbeat

# ── M15: Ambient Context Engine (Push-Autonomie) ────────────────────────────
AUTONOMY_AMBIENT_CONTEXT_ENABLED=true  # sofort aktiv nach Deploy
AMBIENT_SIGNAL_THRESHOLD=0.6           # Mindestscore für Task-Erstellung
AMBIENT_CONFIRM_THRESHOLD=0.85         # Score ab dem Telegram-Push erfolgt
AMBIENT_GOAL_STALE_HOURS=48            # Stunden bis Ziel als stagnierend gilt
AMBIENT_SYSTEM_ALERT_THRESHOLD=0.70    # CPU/RAM/Disk-Schwelle (0.0–1.0)

# ── M16: Echte Lernfähigkeit (Feedback Loop + Qdrant Migration) ─────────────
AUTONOMY_M16_ENABLED=false          # true = Feedback-Hooks aktiv
M16_FEEDBACK_DELTA=0.15             # Weight-Änderung pro 👍/👎 Signal
M16_HOOK_MIN_WEIGHT=0.05            # Minimales Hook-Gewicht (Boden)
M16_HOOK_DECAY_RATE=0.97            # Täglicher Decay Richtung 1.0

# Speicher-Backend
MEMORY_BACKEND=qdrant               # qdrant (Produktivdefault), none (FTS5-only), chromadb nur explizit fuer Legacy/Debug
QDRANT_MODE=server                  # server (Produktiv fuer mcp+dispatcher) oder embedded (nur Legacy/Single-Process)
QDRANT_URL=http://127.0.0.1:6333    # Nur fuer QDRANT_MODE=server
QDRANT_API_KEY=                     # Optional fuer Qdrant-Server
QDRANT_PATH=./data/qdrant_db        # Nur fuer QDRANT_MODE=embedded
QDRANT_COLLECTION=timus_memory      # Collection-Name in Qdrant
QDRANT_SERVER_STORAGE_PATH=/media/fatih-ubuntu/WD6000/timus/qdrant_server/storage   # ext4/XFS empfohlen, nicht NTFS/exFAT
QDRANT_SERVER_SNAPSHOTS_PATH=/media/fatih-ubuntu/WD6000/timus/qdrant_server/snapshots

# ── M14: E-Mail-Autonomie ────────────────────────────────────────────────────
AUTONOMY_M14_ENABLED=false          # true = autonome E-Mail-Aktionen aktiv
EMAIL_BACKEND=smtp                  # smtp (empfohlen) oder msgraph
M14_EMAIL_WHITELIST=user@example.com  # Kommagetrennte Empfänger-Whitelist
M14_EMAIL_CONFIDENCE=0.85           # Confidence-Schwellwert für direkte Sendung
M14_EMAIL_TOPIC_WHITELIST=research,alert,summary  # Erlaubte Topic-Keywords

# SMTP-Konfiguration (für EMAIL_BACKEND=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=                      # Gmail: App-Passwort (nicht Account-Passwort!)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── M13: Tool-Generierung ────────────────────────────────────────────────────
AUTONOMY_M13_ENABLED=false          # true = autonome Tool-Generierung aktiv

# ── M18: Self-Hardening Engine ───────────────────────────────────────────────
AUTONOMY_SELF_HARDENING_ENABLED=false       # true = Timus analysiert Logs und härtet sich selbst
AUTONOMY_SELF_HARDENING_ROLLOUT_STAGE=self_modify_safe  # observe_only | developer_only | self_modify_safe
HARDENING_JOURNAL_UNITS=timus-dispatcher,timus-mcp  # kommagetrennte systemd-Units
HARDENING_JOURNAL_LINES=300                # Anzahl Journal-Zeilen pro Zyklus und Unit
HARDENING_MIN_OCCURRENCES=3               # Mindest-Häufigkeit für einen Proposal
HARDENING_BLACKBOARD_TTL=7200             # Blackboard-TTL in Sekunden (2h)
HARDENING_GOAL_COOLDOWN_HOURS=24          # Cooldown zwischen gleichen Proposals (in Stunden)

# ── Conversation Capsule / Langgespräch-Kontext ──────────────────────────────
TIMUS_CHAT_HISTORY_LIMIT=200
TIMUS_SESSION_ENTRY_LIMIT=24
TIMUS_SESSION_SUMMARY_CHAR_LIMIT=4000
TIMUS_SESSION_STORAGE_ROOT=         # z.B. /media/fatih-ubuntu/WD6000/timus/session_capsules
TIMUS_CHAT_QDRANT_ENABLED=false
TIMUS_CHAT_QDRANT_COLLECTION=timus_conversations
TIMUS_CHAT_QDRANT_PATH=             # Optionaler separater Pfad fuer embedded Chat-Qdrant; im server-Mode ignoriert
TIMUS_CHAT_QDRANT_MAX_RECALL=4
