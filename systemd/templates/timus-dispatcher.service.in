[Unit]
Description=Timus Main Dispatcher (Autonomous Agent)
After=network.target timus-mcp.service qdrant.service
Wants=network.target qdrant.service
Requires=timus-mcp.service qdrant.service
PartOf=timus-stack.target

[Service]
Type=simple
User=__TIMUS_SYSTEM_USER__
WorkingDirectory=__TIMUS_PROJECT_ROOT__
ExecStart=__TIMUS_PYTHON__ main_dispatcher.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=timus-dispatcher
Environment=PYTHONUNBUFFERED=1
Environment=DISPLAY=__TIMUS_DISPLAY__

[Install]
WantedBy=multi-user.target
